{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "Node",
        "types": ["node", "@wdio/globals"],
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "resolveJsonModule": true,
        "isolatedModules": true
    },
    "include": ["./**/*.ts", "./**/*.d.ts"],
    "exclude": ["node_modules"]
}
